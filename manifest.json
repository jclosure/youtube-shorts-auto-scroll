{
  "manifest_version": 3,
  "name": "Auto Scroll YouTube Shorts",
  "version": "1.0.0",
  "description": "Automatically moves to the next YouTube Short when the current video ends.",
  "action": {
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-shorts-auto-scroll@joelholder.com"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
